{
  "schemaVersion": "cellfence.manifest.v1",
  "governance": {
    "requireOwnership": true,
    "include": [
      "packages/lerna/src/**",
      "website/src/**"
    ],
    "exclude": [
      "**/__fixtures__/**",
      "**/__mocks__/**",
      "**/__tests__/**",
      "**/*.bench.*",
      "**/*.benchmark.*",
      "**/*.css",
      "**/*.d.ts",
      "**/*.gen.*",
      "**/*.generated.*",
      "**/*.gif",
      "**/*.jpeg",
      "**/*.jpg",
      "**/*.less",
      "**/*.md",
      "**/*.module.css",
      "**/*.module.scss",
      "**/*.png",
      "**/*.sass",
      "**/*.scss",
      "**/*.spec.*",
      "**/*.stories.*",
      "**/*.story.*",
      "**/*.styl",
      "**/*.svg",
      "**/*.test.*",
      "**/*.vue",
      "**/*.webp",
      "**/bench/**",
      "**/benchmark/**",
      "**/benchmarks/**",
      "**/build/**",
      "**/demo/**",
      "**/demos/**",
      "**/dist/**",
      "**/example/**",
      "**/examples/**",
      "**/fixture/**",
      "**/fixtures/**",
      "**/generated/**",
      "**/test/**",
      "**/tests/**",
      "**/third_party/**",
      "**/vendor/**"
    ],
    "requiredRules": [
      "CELLFENCE_OWNERSHIP_OVERLAP",
      "CELLFENCE_UNOWNED_SOURCE",
      "CELLFENCE_UNOWNED_IMPORT_TARGET",
      "CELLFENCE_PUBLIC_ENTRY_OUTSIDE_OWNERSHIP",
      "CELLFENCE_ARTIFACT_OUTSIDE_OWNERSHIP",
      "CELLFENCE_SYMLINK_TARGET_OUTSIDE_OWNERSHIP",
      "CELLFENCE_PRIVATE_IMPORT",
      "CELLFENCE_UNSUPPORTED_DYNAMIC_IMPORT",
      "CELLFENCE_UNSUPPORTED_DYNAMIC_REQUIRE",
      "CELLFENCE_REQUIRED_RULE_DISABLED",
      "CELLFENCE_WAIVER_INVALID"
    ]
  },
  "cells": [
    {
      "id": "lerna",
      "ownedPaths": [
        "packages/lerna/src/**"
      ],
      "publicEntry": "packages/lerna/src/index.ts",
      "publicSymbols": [
        "default",
        "main",
        "module.exports"
      ],
      "packageName": "lerna",
      "consumes": [],
      "producesArtifacts": []
    },
    {
      "id": "website",
      "ownedPaths": [
        "website/src/**"
      ],
      "publicEntry": "website/src/components/about-lerna.tsx",
      "publicSymbols": [
        "default"
      ],
      "packageName": "website",
      "consumes": [],
      "producesArtifacts": []
    }
  ]
}
