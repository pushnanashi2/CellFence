      "id": "sibling-prefixes-are-distinct",
      "status": "supported-and-tested",
      "ownershipFamily": "sibling-prefixes",
      "files": {
        "src/user/public.ts": ["export const user = true;"],
        "src/users/public.ts": ["export const users = true;"],
        "src/cell1/public.ts": ["export const cell1 = true;"],
        "src/cell10/public.ts": ["export const cell10 = true;"]
      },
      "manifest": {
        "schemaVersion": "cellfence.manifest.v1",
        "governance": { "requireOwnership": true, "include": ["src/**"], "exclude": [] },
        "cells": [
          { "id": "user", "ownedPaths": ["src/user/**"], "publicEntry": "src/user/public.ts", "publicSymbols": ["user"], "consumes": [], "producesArtifacts": [] },
          { "id": "users", "ownedPaths": ["src/users/**"], "publicEntry": "src/users/public.ts", "publicSymbols": ["users"], "consumes": [], "producesArtifacts": [] },
          { "id": "cell1", "ownedPaths": ["src/cell1/**"], "publicEntry": "src/cell1/public.ts", "publicSymbols": ["cell1"], "consumes": [], "producesArtifacts": [] },
          { "id": "cell10", "ownedPaths": ["src/cell10/**"], "publicEntry": "src/cell10/public.ts", "publicSymbols": ["cell10"], "consumes": [], "producesArtifacts": [] }
        ]
      },
      "expected": { "findings": [], "warnings": [] }
    },
