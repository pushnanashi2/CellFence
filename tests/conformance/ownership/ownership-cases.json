      "expected": {
        "findings": [
          { "ruleId": "CELLFENCE_OWNERSHIP_OVERLAP", "severity": "error", "cellId": "shared", "producerCellId": "narrow", "leftPattern": "src/shared/**", "rightPattern": "src/shared/narrow/**" }
