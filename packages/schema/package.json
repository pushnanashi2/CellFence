{
  "name": "@cellfence/schema",
  "version": "0.1.0",
  "description": "CellFence manifest and baseline schema types.",
  "license": "Apache-2.0",
  "type": "module",
  "keywords": [
    "architecture",
    "governance",
    "monorepo",
    "ai-agents"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map",
    "README.md"
  ]
}
