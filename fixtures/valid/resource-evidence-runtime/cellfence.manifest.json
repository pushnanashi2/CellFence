{
  "schemaVersion": "cellfence.manifest.v1",
  "governance": {
    "requireOwnership": true,
    "include": [
      "src/**"
    ],
    "exclude": []
  },
  "cells": [
    {
      "id": "worker",
      "ownedPaths": [
        "src/worker/**"
      ],
      "publicEntry": "src/worker/public.ts",
      "publicSymbols": [
        "runWorker"
      ],
      "resourceContracts": [
        {
          "id": "orders-db",
          "kind": "database",
          "access": [
            "read"
          ],
          "selectors": [
            "app.orders"
          ]
        },
        {
          "id": "orders-queue",
          "kind": "queue",
          "access": [
            "subscribe"
          ],
          "selectors": [
            "orders.ready"
          ]
        },
        {
          "id": "orders-http",
          "kind": "http",
          "access": [
            "call"
          ],
          "selectors": [
            "https://api.example.invalid/orders/status"
          ]
        }
      ],
      "consumes": [],
      "producesArtifacts": []
    }
  ]
}
