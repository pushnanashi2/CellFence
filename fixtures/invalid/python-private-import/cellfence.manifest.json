{
  "schemaVersion": "cellfence.manifest.v1",
  "governance": {
    "requireOwnership": true,
    "include": [
      "src/**"
    ],
    "exclude": []
  },
  "cells": [
    {
      "id": "producer",
      "ownedPaths": [
        "src/producer/**"
      ],
      "publicEntry": "src/producer/public.py",
      "publicSymbols": [
        "exposed"
      ],
      "consumes": [],
      "producesArtifacts": []
    },
    {
      "id": "consumer",
      "ownedPaths": [
        "src/consumer/**"
      ],
      "publicEntry": "src/consumer/public.py",
      "publicSymbols": [
        "used"
      ],
      "consumes": [
        {
          "cell": "producer"
        }
      ],
      "producesArtifacts": []
    }
  ]
}
